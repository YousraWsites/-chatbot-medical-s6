# Auth JWT
SECRET_KEY=change_me_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM provider: openrouter (default, used by Yousra in dev) | gemini (used in Amana prod)
LLM_PROVIDER=openrouter

# OpenRouter (dev / fallback)
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=mistralai/mistral-small-3.2-24b-instruct

# Gemini (Amana prod on sae.amanawebagency.com)
GEMINI_API_KEY=AIzaSy_xxxx
GEMINI_MODEL=gemini-2.5-flash
